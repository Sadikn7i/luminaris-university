# ══════════════════════════════════════════
#   LUMINARIS UNIVERSITY — .gitignore
# ══════════════════════════════════════════

# ── Environment Variables (NEVER commit) ──
.env
.env.local
.env.development
.env.production
.env.test
backend/.env
*.env

# ── Node Modules ──
node_modules/
backend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── MongoDB Local Data ──
data/
*.mongodb

# ── Logs ──
logs/
*.log
backend/logs/

# ── OS Files ──
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ── VS Code ──
.vscode/
*.code-workspace

# ── Uploads (user files) ──
backend/uploads/
assets/uploads/
public/uploads/

# ── Build / Cache ──
dist/
build/
.cache/
.parcel-cache/
.next/

# ── Package Lock (optional) ──
# package-lock.json

# ── Personal Notes ──
notes.txt
todo.txt
personal/
PERSONAL_*